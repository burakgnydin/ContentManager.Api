{
  "ReverseProxy": {
    "Routes": {
      "homepageRoute": {
        "ClusterId": "homepageCluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/homePages/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/HomePage/{**catch-all}" }
        ]
      },
      "aboutRoute": {
        "ClusterId": "aboutCluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/abouts/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/About/{**catch-all}" }
        ]
      },
      "blogRoute": {
        "ClusterId": "blogCluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/blogs/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/Blog/{**catch-all}" }
        ]
      },
      "contactRoute": {
        "ClusterId": "contactCluster",
        "Match": {
          "Path": "{version:regex(^v[0-9]+$)}/contacts/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/ContactPage/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "homepageCluster": {
        "Destinations": {
          "homepageApi": {
            "Address": "http://localhost:5138/"
          }
        }
      },
      "aboutCluster": {
        "Destinations": {
          "aboutApi": {
            "Address": "http://localhost:5032/"
          }
        }
      },
      "blogCluster": {
        "Destinations": {
          "blogApi": {
            "Address": "http://localhost:5027/"
          }
        }
      },
      "contactCluster": {
        "Destinations": {
          "contactApi": {
            "Address": "http://localhost:5030/"
          }
        }
      }
    }
  }
}